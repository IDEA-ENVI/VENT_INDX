SQL> --{
SQL> create or replace function get_min_values(in_date IN char, in_interval IN VARCHAR2)
  2  return number
  3  DETERMINISTIC
  4  is
  5  begin
  6  -- --------------------------------------------------------------------------
  7    --
  8    -- funkce vraci minimalni pocet hodinovych dat pro zapis validnich hodnot.
  9    -- in_date je datum
 10    -- in_interval nabyva jedne z techto hodnot: DD nebo MM nebo YYYY
 11    -- nov
 12    -- 2026-01-19
 13    -- --------------------------------------------------------------------------
 14  	declare
 15  	   w_date	  date;
 16  	   w_interval	  varchar2(20);
 17  	   w_return	  number(5,0);
 18  	   w_is_leap_year number(1,0);
 19  	   w_month	  number(2,0);
 20  	begin
 21  	   w_date		   := in_date;
 22  	   w_interval		   := in_interval;
 23  	   w_is_leap_year	   := 0; --0/1 - nejedna/jedna se o prestupny rok
 24  	   w_return		   := 0;
 25  
 26  	   w_is_leap_year := TO_CHAR(LAST_DAY(TO_DATE('02-' || EXTRACT(YEAR FROM w_date), 'MM-YYYY')), 'DD')-28;
 27  	   w_month := EXTRACT(MONTH FROM w_date);
 28  	   IF w_interval = 'DD' THEN
 29  	      w_return := 22;
 30  	   ELSIF w_interval = 'MM' THEN
 31  	      CASE
 32  		 WHEN w_month in (1,3,5,7,8,10,12) THEN
 33  		    w_return := 670;
 34  		 WHEN w_month in (4,6,9,11) THEN
 35  		    w_return := 648;
 36  		 WHEN w_month in (2) THEN
 37  		    IF w_is_leap_year = 0 THEN
 38  		       w_return := 605;
 39  		    ELSE
 40  		       w_return := 626;
 41  		    END IF;
 42  	      END CASE;
 43  	   ELSIF w_interval = 'YYYY' THEN
 44  	      IF w_is_leap_year = 0 THEN
 45  		 w_return := 7884;
 46  	      ELSE
 47  		 w_return := 7906;
 48  	      END IF;
 49  	   END IF;
 50  	   return w_return;
 51  	end;
 52  end get_min_values;
